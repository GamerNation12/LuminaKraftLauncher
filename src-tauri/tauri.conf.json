{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nebula Launcher",
  "version": "0.1.8",
  "identifier": "NebulaLauncher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nebula Launcher",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "dragDropEnabled": false,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self' https://iytnvsdsqvbdoqesyweo.supabase.co; img-src 'self' data: https: file: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https://iytnvsdsqvbdoqesyweo.supabase.co https://cdn.nebula-launcher.com https://*.r2.cloudflarestorage.com file:"
    },
    "trayIcon": null,
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "app",
      "dmg",
      "appimage"
    ],
    "createUpdaterArtifacts": true,
    "publisher": "Nebula",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "allowDowngrades": true,
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "compression": "lzma"
      }
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "shell": {
      "open": true
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://raw.githubusercontent.com/Nebula/NebulaLauncher/main/latest.json",
        "https://github.com/Nebula/NebulaLauncher/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxOTdFMkYzMDE2QkFFMjYKUldRbXJtc0I4K0tYd2J2elpMQXhLNmN3S3R1Q3c0REVMczdiQTAxRzhDRzg4Z1VocTlVdGxYV1UK"
    }
  }
}